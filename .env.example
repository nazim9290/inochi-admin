# Inochi Global Education — Admin dashboard (Vite + React)
# Copy this file to .env and fill in real values. Never commit .env.
# Vite exposes only VITE_-prefixed vars to the browser.

# Backend API base URL (replaces hardcoded https://api.inochieducation.com/api/)
VITE_API_BASE_URL=https://api.inochieducation.com/api/

# YouTube Data API key (currently hardcoded in src/components/CreatePlaylis.jsx — move here)
VITE_YOUTUBE_API_KEY=replace_with_your_youtube_data_api_key
